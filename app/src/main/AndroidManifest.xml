<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <application
        android:name=".App"
        android:label="@string/app_name"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:theme="@style/Theme.NotifGestureFix">

        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Xposed module marker -->
        <meta-data
            android:name="xposedmodule"
            android:value="true" />

        <!-- Module description -->
        <meta-data
            android:name="xposeddescription"
            android:value="Fixes broken swipe-to-expand on notifications after lock/unlock (ColorOS/OxygenOS keyguard-state bug)" />

        <!-- Minimum Xposed API version -->
        <meta-data
            android:name="xposedminversion"
            android:value="82" />

        <!-- LSPosed scope -->
        <meta-data
            android:name="xposedscope"
            android:resource="@array/xposed_scope" />
    </application>

</manifest>
